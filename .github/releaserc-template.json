{
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    "@anolilab/semantic-release-pnpm",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node dist/scripts/apply-skill-changesets.js && node dist/scripts/apply-plugin-changesets.js && node dist/scripts/sync-version.js && node dist/cli/export-claude.js && node dist/scripts/distribute-mcp.js"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "gemini-extension.json",
          ".claude-plugin/marketplace.json",
          ".agent-structurerc",
          "plugins/**",
          ".changeset/**",
          "skills/**"
        ]
      }
    ],
    "@semantic-release/github"
  ]
}