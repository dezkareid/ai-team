{
  "name": "@dezkareid/ai-team",
  "version": "0.0.0",
  "description": "Repository for AI Team",
  "type": "module",
  "main": "index.js",
  "bin": {
    "ai-team-mcp": "./dist/mcp-server/index.js"
  },
  "scripts": {
    "sync-version": "node dist/scripts/sync-version.js",
    "distribute-mcp": "node dist/scripts/distribute-mcp.js",
    "build": "rollup -c",
    "test": "vitest run && npm run test:marketplace",
    "test:marketplace": "ajv validate -s schemas/marketplace.schema.json -d .claude-plugin/marketplace.json",
    "export-claude": "node dist/cli/export-claude.js",
    "apply-skill-changesets": "node dist/scripts/apply-skill-changesets.js",
    "apply-plugin-changesets": "node dist/scripts/apply-plugin-changesets.js"
  },
  "keywords": [],
  "files": [
    "README.md",
    "AGENTS.md",
    "gemini-extension.json",
    "context",
    ".agent-structurerc"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dezkareid/ai-team.git"
  },
  "author": "Joel Humberto Gomez Paredes <elmaildeldezkareid@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dezkareid/ai-team/issues"
  },
  "homepage": "https://github.com/dezkareid/ai-team#readme",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@changesets/cli": "2.29.8",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.0.10",
    "@types/semver": "7.7.1",
    "ajv-cli": "5.0.0",
    "rollup": "4.56.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "@dezkareid/design-tokens": "1.3.1",
    "@iarna/toml": "2.2.5",
    "@modelcontextprotocol/sdk": "1.27.1",
    "fs-extra": "11.3.3",
    "semver": "7.7.4",
    "yaml": "2.8.2",
    "zod": "4.3.6"
  }
}