{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Marketplace Schema",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string" },
    "owner": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "url": { "type": "string" }
      },
      "required": ["name"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "description": { "type": "string" },
          "source": { "type": "string" }
        },
        "required": ["name", "source"]
      }
    }
  },
  "required": ["name", "owner", "plugins"]
}
